# Backend API origin used by production builds (Vercel).
# Set this to the deployed Render URL, with NO trailing slash and NO /brief:
#   VITE_API_URL=https://seo-intel-api.onrender.com
#
# Leave it unset for local development — the Vite dev proxy (/api -> :8000,
# see vite.config.ts) handles routing to the local backend.
#
# NOTE: Vite inlines VITE_* vars at BUILD time, so this must be set in Vercel
# before/at build, not at runtime.
VITE_API_URL=
