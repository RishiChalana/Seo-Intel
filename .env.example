# LLM
GEMINI_API_KEY=

# Search provider.
# Without this the app uses MockSearchProvider (deterministic fixtures) -
# useful for local dev/demo without a paid API key.
SERPAPI_KEY=

# Full-page scraping (requires SERPAPI_KEY).
# When true (default), SerpAPIProvider fetches each competitor URL and extracts
# the full article body with trafilatura, giving the RAG store 10-20x more
# context than SERP snippets alone. Pages that fail to fetch (403, timeout, or
# thin content) automatically fall back to their snippet - one bad URL never
# breaks the run. Set to false for faster runs with snippet-only RAG context.
SCRAPE_FULL_PAGES=true

# Embedding backend: "tfidf" (default, free, local) or "voyage" (production quality)
EMBEDDING_BACKEND=tfidf
VOYAGE_API_KEY=
